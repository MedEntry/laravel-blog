{
    "name": "binshops/laravel-blog",
    "keywords": [
        "laravel",
        "blog",
        "package",
        "admin",
        "panel",
        "rss",
        "feed",
        "write",
        "posts",
        "news",
        "update",
        "laravel blog",
        "binshops"
    ],
    "description": "Simple blog package (with admin panel) for Laravel. Includes all views, controllers, routes and can add a blog to any existing Laravel app. Fully customisable blog (view, urls, and many other options). Includes image uploads and a pretty admin interface to manage your blog. Defaults to /blog but you can change it to anything.",
    "license": "MIT",
    "support": {
        "docs": "https://github.com/binshops/laravel-blog"
    },
    "authors": [
        {
            "name": "Binshops",
            "homepage": "https://github.com/binshops/laravel-blog",
            "role": "owner",
            "email": "contact@binshops.com"
        }
    ],
    "require": {
        "cviebrock/eloquent-sluggable": "^13.0|^12.0|^11.0|^10.0|^9.0|~8.0|~7.0|~6.0",
        "intervention/image": "^4.2|2.*",
        "laravel/helpers": "^1.3",
        "swisnl/laravel-fulltext": "^0.23.1"
    },
    "require-dev": {
        "phpunit/phpunit": "*",
        "orchestra/testbench": "^11.0|^10.0|^9.0|^8.0|^7.0|^6.0",
        "php-coveralls/php-coveralls": "*",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "BinshopsBlog\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BinshopsBlog\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BinshopsBlog\\BinshopsBlogServiceProvider"
            ],
            "aliases": {
            }
        }
    }
}
